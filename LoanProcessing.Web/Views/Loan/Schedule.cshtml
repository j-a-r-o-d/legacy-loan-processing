@model IEnumerable<LoanProcessing.Web.Models.PaymentSchedule>

@{
    ViewBag.Title = "Payment Schedule";
    var application = ViewBag.Application as LoanProcessing.Web.Models.LoanApplication;
}

<h2>Payment Schedule</h2>

@if (application != null)
{
    <div class="row">
        <div class="col-md-12">
            <div class="panel panel-success">
                <div class="panel-heading">
                    <h3 class="panel-title">Loan Information</h3>
                </div>
                <div class="panel-body">
                    <div class="row">
                        <div class="col-md-6">
                            <dl class="dl-horizontal">
                                <dt>Application #:</dt>
                                <dd>@application.ApplicationNumber</dd>

                                <dt>Customer:</dt>
                                <dd>
                                    @if (application.Customer != null)
                                    {
                                        @Html.ActionLink(application.Customer.FirstName + " " + application.Customer.LastName, "Details", "Customer", new { id = application.CustomerId }, null)
                                    }
                                    else
                                    {
                                        <text>Customer ID: @application.CustomerId</text>
                                    }
                                </dd>

                                <dt>Loan Type:</dt>
                                <dd>@application.LoanType</dd>
                            </dl>
                        </div>
                        <div class="col-md-6">
                            <dl class="dl-horizontal">
                                <dt>Approved Amount:</dt>
                                <dd>@application.ApprovedAmount.Value.ToString("C")</dd>

                                <dt>Interest Rate:</dt>
                                <dd>@application.InterestRate.Value.ToString("0.00")%</dd>

                                <dt>Term:</dt>
                                <dd>@application.TermMonths months</dd>
                            </dl>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@if (Model != null && Model.Any())
{
    var totalPayments = Model.Sum(s => s.PaymentAmount);
    var totalPrincipal = Model.Sum(s => s.PrincipalAmount);
    var totalInterest = Model.Sum(s => s.InterestAmount);
    var firstPayment = Model.First();
    var lastPayment = Model.Last();

    <div class="row">
        <div class="col-md-12">
            <div class="panel panel-info">
                <div class="panel-heading">
                    <h3 class="panel-title">Payment Summary</h3>
                </div>
                <div class="panel-body">
                    <div class="row">
                        <div class="col-md-3">
                            <div class="text-center">
                                <h4>Total Payments</h4>
                                <h3 class="text-primary">@Model.Count()</h3>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="text-center">
                                <h4>Total Amount</h4>
                                <h3 class="text-primary">@totalPayments.ToString("C")</h3>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="text-center">
                                <h4>Total Principal</h4>
                                <h3 class="text-success">@totalPrincipal.ToString("C")</h3>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="text-center">
                                <h4>Total Interest</h4>
                                <h3 class="text-danger">@totalInterest.ToString("C")</h3>
                            </div>
                        </div>
                    </div>
                    <hr />
                    <div class="row">
                        <div class="col-md-6">
                            <dl class="dl-horizontal">
                                <dt>First Payment Date:</dt>
                                <dd>@firstPayment.DueDate.ToString("MM/dd/yyyy")</dd>
                            </dl>
                        </div>
                        <div class="col-md-6">
                            <dl class="dl-horizontal">
                                <dt>Final Payment Date:</dt>
                                <dd>@lastPayment.DueDate.ToString("MM/dd/yyyy")</dd>
                            </dl>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-12">
            <div class="panel panel-default">
                <div class="panel-heading">
                    <h3 class="panel-title">Amortization Schedule</h3>
                </div>
                <div class="table-responsive">
                    <table class="table table-striped table-hover" id="scheduleTable">
                        <thead>
                            <tr>
                                <th>Payment #</th>
                                <th>Due Date</th>
                                <th class="text-right">Payment Amount</th>
                                <th class="text-right">Principal</th>
                                <th class="text-right">Interest</th>
                                <th class="text-right">Remaining Balance</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var payment in Model)
                            {
                                <tr>
                                    <td>@payment.PaymentNumber</td>
                                    <td>@payment.DueDate.ToString("MM/dd/yyyy")</td>
                                    <td class="text-right">@payment.PaymentAmount.ToString("C")</td>
                                    <td class="text-right text-success">@payment.PrincipalAmount.ToString("C")</td>
                                    <td class="text-right text-danger">@payment.InterestAmount.ToString("C")</td>
                                    <td class="text-right">
                                        @if (payment.RemainingBalance == 0)
                                        {
                                            <strong class="text-success">@payment.RemainingBalance.ToString("C")</strong>
                                        }
                                        else
                                        {
                                            @payment.RemainingBalance.ToString("C")
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                        <tfoot>
                            <tr class="info">
                                <th colspan="2" class="text-right">Totals:</th>
                                <th class="text-right">@totalPayments.ToString("C")</th>
                                <th class="text-right text-success">@totalPrincipal.ToString("C")</th>
                                <th class="text-right text-danger">@totalInterest.ToString("C")</th>
                                <th></th>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>
    </div>
}
else
{
    <div class="alert alert-warning">
        <strong>No payment schedule found.</strong> Payment schedules are generated when a loan application is approved.
    </div>
}

<div class="row">
    <div class="col-md-12">
        <p>
            @if (application != null)
            {
                @Html.ActionLink("Back to Application", "Details", new { id = application.ApplicationId }, new { @class = "btn btn-default" })
            }
            @Html.ActionLink("Back to List", "Index", null, new { @class = "btn btn-default" })
        </p>
    </div>
</div>

@section scripts {
    <script>
        $(document).ready(function () {
            // Add print functionality
            $('<button class="btn btn-primary pull-right" style="margin-top: -50px;"><span class="glyphicon glyphicon-print"></span> Print Schedule</button>')
                .insertBefore('#scheduleTable')
                .click(function () {
                    window.print();
                });
        });
    </script>
    <style>
        @@media print {
            .navbar, .btn, footer, .alert {
                display: none !important;
            }
            .panel {
                border: 1px solid #ddd !important;
            }
        }
    </style>
}
